# Fablesol environment configuration
# Copy to .env.local for local development. All values are optional in
# Phase 1 — public pages work without any of them.

# Canonical site URL used for metadata, sitemap, and canonical links.
NEXT_PUBLIC_SITE_URL=https://fablesol.com

# Official community links (the only approved social platforms).
# Leave unset until the official servers/accounts exist — the UI shows an
# honest "opens soon" state instead of a dead link.
NEXT_PUBLIC_DISCORD_URL=
NEXT_PUBLIC_X_URL=

# Hosted Supabase project (no Docker anywhere in this workflow).
# Find these in the Supabase dashboard under Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only privileged key. NEVER prefix with NEXT_PUBLIC_, never commit,
# never import into client components.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Phase 2B wallet connection and $FABLE access gate
# ---------------------------------------------------------------------------

# Public wallet-provider project identifier (safe for the browser bundle).
# Create it in the wallet provider dashboard; without it, wallet connection
# shows an honest "not available" state.
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Supported values: solana:mainnet-beta or solana:devnet
NEXT_PUBLIC_SOLANA_NETWORK=solana:devnet

# Server-only Solana RPC endpoint. May contain credentials; never expose with
# NEXT_PUBLIC_ and never log it.
SOLANA_RPC_URL=

# Server-only $FABLE mint address. Leave unset until the real mint exists;
# protected access then fails safe and no balance is ever fabricated.
FABLE_TOKEN_MINT=

# Whole-token access threshold. The approved game rule is 10000.
FABLE_ACCESS_REQUIRED_TOKENS=10000

# Signature challenge lifetime in seconds (60 to 900).
WALLET_CHALLENGE_TTL_SECONDS=300

# Protected access-session lifetime in seconds (60 to 3600).
PLAYER_ACCESS_SESSION_TTL_SECONDS=300
